[Unit]
Description=MAX BOT - Discord Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/maxbot
ExecStart=/opt/maxbot/venv/bin/python -u main.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
StandardOutput=append:/opt/maxbot/logs/bot.log
StandardError=append:/opt/maxbot/logs/bot.log

[Install]
WantedBy=multi-user.target
